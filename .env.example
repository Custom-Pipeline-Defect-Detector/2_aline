POSTGRES_DB=aline
POSTGRES_USER=aline
POSTGRES_PASSWORD=alinepass
JWT_SECRET=change_me_to_a_long_random_secret

WATCH_PATH=C:\AlineInbox
FILE_STORAGE_ROOT=C:\AlineStorage
WEB_PORT=9876


# Database
POSTGRES_DB=aline
POSTGRES_USER=aline
POSTGRES_PASSWORD=alinepass
DATABASE_URL=postgresql+psycopg2://aline:alinepass@localhost:5432/aline

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-it-please

# File Storage

# OpenAI Compatible API Configuration (DashScope)
OPENAI_API_KEY=replace_with_your_api_key
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
MODEL_NAME=qwen3-coder-plus

# AI automation control
AI_UNRESTRICTED_TOOL_EXECUTION=true
AI_AUTONOMOUS_EXECUTE=true
AUTO_APPROVE_PROPOSALS=true

# Internal API key for watcher
API_KEY_INTERNAL=internal_watcher_key_change_me

# Application settings for robustness
REQUEST_TIMEOUT=60
MAX_FILE_SIZE=50
LOG_LEVEL=INFO
HEALTH_CHECK_INTERVAL=30

# Security settings
SECURE_COOKIES=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=300

# Web port
WEB_PORT=9876
