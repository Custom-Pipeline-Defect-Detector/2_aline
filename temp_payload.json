+def search_worklogs(args: SearchWorklogArgs) -> ToolResult:
+    db = _get_db()
+    try:
+        query = db.query(models.WorkLog)
+        if args.project_id:
+            query = query.filter(models.WorkLog.project_id == args.project_id)
+        if args.user_id:
+            query = query.filter(models.WorkLog.user_id == args.user_id)
